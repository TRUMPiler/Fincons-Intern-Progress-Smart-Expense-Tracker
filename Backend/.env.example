# Backend Environment Configuration

# Server Port (from CORS error, backend runs on 8080)
PORT=8080

# Used for CORS configuration (frontend URL)
FRONTEND_URL=http://localhost:5173

# Database Configuration
# (add your existing DB config values)

# JWT Secret
JWTSECRET=your_jwt_secret_key_here

# Email Configuration  
# (add your existing email config)

# Node Environment
NODE_ENV=development
